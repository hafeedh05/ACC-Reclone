{
  "name": "ad-command-center",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "dev:web": "pnpm --dir apps/web dev",
    "build:web": "pnpm --dir apps/web build",
    "lint:web": "pnpm --dir apps/web lint",
    "typecheck:web": "pnpm --dir apps/web exec tsc --noEmit",
    "run:api": "cargo run --manifest-path services/Cargo.toml -p api",
    "run:orchestrator": "cargo run --manifest-path services/Cargo.toml -p orchestrator",
    "run:workers": "cargo run --manifest-path services/Cargo.toml -p workers -- --help",
    "check:rust": "cargo check --manifest-path services/Cargo.toml --workspace",
    "test:rust": "cargo test --manifest-path services/Cargo.toml --workspace",
    "fmt:rust": "cargo fmt --manifest-path services/Cargo.toml --all",
    "fmt:rust:check": "cargo fmt --manifest-path services/Cargo.toml --all --check",
    "verify": "pnpm lint:web && pnpm typecheck:web && pnpm fmt:rust:check && pnpm check:rust && pnpm test:rust"
  }
}
