{
  "meta": {
    "name": "Ad Command Center",
    "mode": "dark-first",
    "version": "v1"
  },
  "color": {
    "bg": {
      "canvas": "#0F1115",
      "canvasAlt": "#13161B",
      "surface": "#171B21",
      "surfaceRaised": "#1D222A",
      "surfaceTonal": "#232934",
      "surfaceOverlay": "rgba(10,12,15,0.72)",
      "surfaceInverse": "#F6F2EA"
    },
    "text": {
      "primary": "#F6F2EA",
      "secondary": "#D7D0C5",
      "muted": "#9A9389",
      "soft": "#767068",
      "inverse": "#0F1115",
      "accent": "#E3B06F"
    },
    "border": {
      "subtle": "rgba(246,242,234,0.08)",
      "default": "rgba(246,242,234,0.14)",
      "strong": "rgba(246,242,234,0.22)",
      "focus": "rgba(227,176,111,0.42)"
    },
    "accent": {
      "amberSoft": "#E6BA84",
      "amberBase": "#D49A5A",
      "amberStrong": "#B97835",
      "cobaltSoft": "#7C8FB8",
      "cobaltBase": "#5E729B",
      "cobaltStrong": "#445777"
    },
    "status": {
      "success": "#73927D",
      "warning": "#BD8A4A",
      "error": "#A86963",
      "info": "#6F86A7"
    },
    "mediaPlate": {
      "shadow": "rgba(0,0,0,0.34)",
      "backdrop": "#101317",
      "scrimTop": "rgba(15,17,21,0.04)",
      "scrimBottom": "rgba(15,17,21,0.42)"
    }
  },
  "typography": {
    "family": {
      "ui": "Instrument Sans",
      "editorial": "Instrument Serif",
      "mono": "IBM Plex Mono"
    },
    "scale": {
      "displayXxl": {
        "fontFamily": "Instrument Sans",
        "fontSize": 72,
        "lineHeight": 76,
        "letterSpacing": -0.05,
        "fontWeight": 600
      },
      "displayXl": {
        "fontFamily": "Instrument Sans",
        "fontSize": 56,
        "lineHeight": 60,
        "letterSpacing": -0.045,
        "fontWeight": 600
      },
      "headlineLg": {
        "fontFamily": "Instrument Sans",
        "fontSize": 42,
        "lineHeight": 48,
        "letterSpacing": -0.04,
        "fontWeight": 600
      },
      "headlineMd": {
        "fontFamily": "Instrument Sans",
        "fontSize": 34,
        "lineHeight": 40,
        "letterSpacing": -0.03,
        "fontWeight": 600
      },
      "titleLg": {
        "fontFamily": "Instrument Sans",
        "fontSize": 26,
        "lineHeight": 32,
        "letterSpacing": -0.02,
        "fontWeight": 600
      },
      "titleMd": {
        "fontFamily": "Instrument Sans",
        "fontSize": 22,
        "lineHeight": 28,
        "letterSpacing": -0.018,
        "fontWeight": 600
      },
      "bodyLg": {
        "fontFamily": "Instrument Sans",
        "fontSize": 18,
        "lineHeight": 30,
        "letterSpacing": -0.01,
        "fontWeight": 400
      },
      "bodyMd": {
        "fontFamily": "Instrument Sans",
        "fontSize": 16,
        "lineHeight": 26,
        "letterSpacing": -0.008,
        "fontWeight": 400
      },
      "bodySm": {
        "fontFamily": "Instrument Sans",
        "fontSize": 14,
        "lineHeight": 22,
        "letterSpacing": -0.006,
        "fontWeight": 400
      },
      "label": {
        "fontFamily": "Instrument Sans",
        "fontSize": 12,
        "lineHeight": 16,
        "letterSpacing": 0.18,
        "fontWeight": 500,
        "textTransform": "uppercase"
      },
      "eyebrow": {
        "fontFamily": "IBM Plex Mono",
        "fontSize": 11,
        "lineHeight": 16,
        "letterSpacing": 0.24,
        "fontWeight": 500,
        "textTransform": "uppercase"
      },
      "editorialPullquote": {
        "fontFamily": "Instrument Serif",
        "fontSize": 34,
        "lineHeight": 40,
        "letterSpacing": -0.02,
        "fontWeight": 400
      }
    }
  },
  "space": {
    "0": 0,
    "1": 4,
    "2": 8,
    "3": 12,
    "4": 16,
    "5": 20,
    "6": 24,
    "8": 32,
    "10": 40,
    "12": 48,
    "16": 64,
    "20": 80,
    "24": 96,
    "26": 104,
    "32": 128
  },
  "radius": {
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 24,
    "xxl": 32,
    "display": 40,
    "pill": 999
  },
  "shadow": {
    "soft": "0 16 40 0 rgba(0,0,0,0.18)",
    "medium": "0 28 64 0 rgba(0,0,0,0.26)",
    "hero": "0 42 90 0 rgba(0,0,0,0.34)",
    "focus": "0 0 0 1 rgba(227,176,111,0.28), 0 0 0 4 rgba(227,176,111,0.12)"
  },
  "layout": {
    "breakpoints": {
      "mobile": 390,
      "tablet": 1024,
      "desktop": 1440,
      "wide": 1600
    },
    "container": {
      "article": 760,
      "default": 1280,
      "wide": 1440
    },
    "grid": {
      "desktopColumns": 12,
      "tabletColumns": 8,
      "mobileColumns": 4,
      "desktopGutter": 24,
      "tabletGutter": 20,
      "mobileGutter": 16
    },
    "section": {
      "desktopY": 104,
      "tabletY": 88,
      "mobileY": 64
    },
    "nav": {
      "desktopHeight": 88,
      "mobileHeight": 72
    }
  },
  "motion": {
    "duration": {
      "fast": 120,
      "base": 180,
      "slow": 260,
      "linger": 420
    },
    "easing": {
      "standard": "cubic-bezier(0.2, 0.8, 0.2, 1)",
      "decelerate": "cubic-bezier(0.16, 1, 0.3, 1)",
      "accelerate": "cubic-bezier(0.4, 0, 1, 1)"
    },
    "parallax": {
      "heroTranslateY": 10,
      "hoverScale": 1.015
    }
  },
  "icon": {
    "sizes": {
      "sm": 16,
      "md": 20,
      "lg": 24
    },
    "stroke": {
      "default": 1.5,
      "strong": 2
    }
  },
  "media": {
    "ratios": {
      "portrait": "4:5",
      "square": "1:1",
      "story": "9:16",
      "landscape": "16:9",
      "browser": "16:10"
    },
    "framing": {
      "browserRadius": 24,
      "deviceRadius": 28,
      "thumbnailRadius": 18,
      "shadowPlateRadius": 32
    },
    "rules": {
      "plate": "Every hero or gallery asset sits on a subtle shadow plate so art can be swapped without re-composing the section.",
      "cropping": "Favor centered product focus with generous negative space; never crop through key labels or pack shots.",
      "placeholder": "If the final asset is missing, use a neutral framed placeholder labeled with the required asset name and target dimensions."
    }
  }
}
